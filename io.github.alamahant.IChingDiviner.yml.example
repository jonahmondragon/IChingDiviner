app-id: io.github.alamahant.IChingDiviner
runtime: org.kde.Platform
runtime-version: '6.10'
sdk: org.kde.Sdk
command: IChingDiviner
finish-args:
  - --share=ipc
  - --socket=fallback-x11
  - --socket=wayland
  - --device=dri
  - --share=network
modules:
  - name: IChingDiviner
    buildsystem: cmake-ninja
    config-opts:
      - -DFLATPAK_BUILD=ON
      - -DCMAKE_BUILD_TYPE=Release
    sources:
      - type: git
        url: https://github.com/alamahant/IChingDiviner.git
        tag: v1.0.0
        commit: a279126382a25d6208016ff5354e8b6de68aecb7
      
